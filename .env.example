# Neon PostgreSQL (same instance as AautiLearn, uses verifyiq schema)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST_DIRECT/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32

# IDfy PAN Verification
IDFY_API_KEY=your_idfy_api_key
IDFY_BASE_URL=https://eve.idfy.com/v3/tasks

# SerpAPI for internet sweep
SERPAPI_KEY=your_serpapi_key
