generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["verifyiq"]
}

model Tenant {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  apiKey      String   @unique @map("api_key")
  webhookUrl  String?  @map("webhook_url")
  plan        String   @default("free")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  verifications Verification[]
  users         User[]

  @@map("tenants")
  @@schema("verifyiq")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String   @unique
  password  String
  name      String?
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Account Account[]
  Session Session[]

  @@map("users")
  @@schema("verifyiq")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("verifyiq")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("verifyiq")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("verifyiq")
}

model Verification {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  subjectName   String    @map("subject_name")
  panNumber     String?   @map("pan_number")
  aadhaarNumber String?   @map("aadhaar_number")
  linkedinUrl   String?   @map("linkedin_url")
  phone         String?
  city          String?
  candidateEmail String?  @map("candidate_email")
  status        String    @default("pending")
  riskScore     Int?      @map("risk_score")
  results       Json?
  callbackUrl   String?   @map("callback_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  // Candidate verification token (magic link)
  verifyToken    String?   @unique @map("verify_token")
  tokenExpiresAt DateTime? @map("token_expires_at")

  // Image URLs (Vercel Blob)
  selfieUrl      String?  @map("selfie_url")
  aadhaarCardUrl String?  @map("aadhaar_card_url")
  panCardUrl     String?  @map("pan_card_url")

  // OCR extracted values
  ocrPanNumber     String? @map("ocr_pan_number")
  ocrAadhaarNumber String? @map("ocr_aadhaar_number")

  // Face match
  faceMatchScore  Float?  @map("face_match_score")
  faceMatchStatus String? @map("face_match_status")

  // Admin review
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNotes  String?   @map("review_notes")

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checks VerificationCheck[]

  @@map("verifications")
  @@schema("verifyiq")
}

model VerificationCheck {
  id             String   @id @default(uuid())
  verificationId String   @map("verification_id")
  checkType      String   @map("check_type")
  status         String   @default("pending")
  rawResponse    Json?    @map("raw_response")
  createdAt      DateTime @default(now()) @map("created_at")

  verification Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@map("verification_checks")
  @@schema("verifyiq")
}
